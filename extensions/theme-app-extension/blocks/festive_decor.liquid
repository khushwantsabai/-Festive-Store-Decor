{% assign config = app.metafields.festive.template_config.value %}
{% assign active_template = config.templateName %}

{% if active_template == blank %}
  {% if request.design_mode %}
    <div style="padding: 20px; background: #f4f4f4; border: 2px dashed #ccc; text-align: center; border-radius: 8px; margin: 20px 0;">
      <h2 style="margin: 0 0 10px 0;">Festive Store Decor</h2>
      <p style="margin: 0;">Please publish a template from the App Admin first!</p>
    </div>
  {% endif %}
{% else %}

  {% assign textContent = config.textContent %}
  {% assign buttonText = config.buttonText %}
  {% assign bgColor = config.bgColor %}
  {% assign btnBgColor = config.btnBgColor %}
  {% assign textColor = config.textColor | default: 'inherit' %}
  {% assign showCloseButton = config.showCloseButton %}

  {% if active_template contains 'Popup' %}
    <div style="position: fixed; bottom: 20px; right: 20px; padding: 20px; border-radius: 12px; z-index: 99999; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); width: 300px; text-align: center; color: {{ textColor }}; display: flex; flex-direction: column; align-items: center; 
    {% if bgColor != blank %}
      background-color: {{ bgColor }};
    {% else %}
      background-color: #064E3B;
    {% endif %}
    ">
      
      {% if showCloseButton != false %}
      <span style="position: absolute; top: 10px; right: 10px; cursor: pointer; font-size: 16px;" onclick="this.parentElement.style.display='none'">❌</span>
      {% endif %}
      
      <h3 style="margin: 0 0 5px 0; font-size: 18px; font-weight: bold;">
        {% if textContent != blank %}{{ textContent }}{% else %}{{ active_template }}{% endif %}
      </h3>
      
      {% case active_template %}
        {% when 'Christmas Popup' %}<div style="font-size: 40px; margin: 10px 0;">🎅</div>
        {% when 'Spin & Win Popup' %}<div style="font-size: 40px; margin: 10px 0;">🎡</div>
        {% when 'Exit Intent Popup' %}<div style="font-size: 40px; margin: 10px 0;">🎁</div>
        {% when 'New Year Popup' %}<div style="font-size: 40px; margin: 10px 0;">🎆</div>
        {% when 'Flash Sale Popup' %}<div style="font-size: 40px; margin: 10px 0;">⚡</div>
        {% when 'Welcome Popup' %}<div style="font-size: 40px; margin: 10px 0;">👋</div>
        {% when 'Free Shipping Popup' %}<div style="font-size: 40px; margin: 10px 0;">🚚</div>
        {% when 'Newsletter Popup' %}<div style="font-size: 40px; margin: 10px 0;">✉️</div>
      {% endcase %}
      
      <input type="email" placeholder="Enter your email" style="width: 100%; padding: 10px; margin-bottom: 10px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;" />
      <button style="width: 100%; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: bold; color: inherit;
      {% if btnBgColor != blank %}background-color: {{ btnBgColor }};{% else %}background: rgba(255,255,255,0.2);{% endif %}
      ">{% if buttonText != blank %}{{ buttonText }}{% else %}Subscribe{% endif %}</button>
    </div>
  {% else %}
    <div style="padding: 15px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 20px; color: {{ textColor }}; border-radius: 8px; text-align: left;
    {% if bgColor != blank %}
      background-color: {{ bgColor }};
    {% else %}
      background: linear-gradient(to right, #064E3B, #047857);
    {% endif %}
    ">
      
      {% case active_template %}
        {% when 'Merry Christmas' %}<div style="font-size: 40px;">🎅</div>
        {% when 'Happy Diwali' %}<div style="font-size: 40px;">🪔</div>
        {% when 'Black Friday Sale' %}<div style="font-size: 40px;">🖤</div>
        {% when 'Valentine' %}<div style="font-size: 40px;">💖</div>
        {% when 'Cyber Monday' %}<div style="font-size: 40px;">💻</div>
        {% when 'Halloween Spooktacular' %}<div style="font-size: 40px;">🦇</div>
        {% when 'Spring Collection' %}<div style="font-size: 40px;">🌸</div>
        {% else %}<div style="font-size: 40px;">🎉</div>
      {% endcase %}

      <div>
        <h2 style="margin: 0; font-size: 1.5rem; font-weight: bold;">
          {% if textContent != blank %}{{ textContent }}{% else %}{{ active_template }}{% endif %}
        </h2>
        {% if buttonText != blank %}
        <button style="margin-top: 10px; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; color: inherit;
        {% if btnBgColor != blank %}background-color: {{ btnBgColor }};{% else %}background: rgba(255,255,255,0.2);{% endif %}
        ">
          {{ buttonText }}
        </button>
        {% endif %}
      </div>
    </div>
  {% endif %}

{% endif %}

{% schema %}
{
  "name": "Festive Decor",
  "target": "section",
  "settings": []
}
{% endschema %}
