{% assign active_template = app.metafields.festive.active_template.value %}

{% if active_template == blank %}
  <div style="padding: 20px; background: #f4f4f4; border: 2px dashed #ccc; text-align: center; border-radius: 8px; margin: 20px 0;">
    <h2 style="margin: 0 0 10px 0;">Festive Store Decor</h2>
    <p style="margin: 0;">Please publish a template from the App Admin first!</p>
  </div>
{% else %}
  
  {% if active_template contains 'Popup' %}
    <div style="position: fixed; bottom: 20px; right: 20px; background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; padding: 20px; border-radius: 12px; z-index: 99999; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); width: 300px; text-align: center;">
      <h3 style="margin-top: 0;">{{ block.settings.title | default: active_template }}</h3>
      <p>{{ block.settings.subtitle }}</p>
      <input type="email" placeholder="Enter your email" style="width: 100%; padding: 8px; margin-bottom: 10px; border: 1px solid #ccc; border-radius: 4px;" />
      <button style="width: 100%; background: #000; color: #fff; border: none; padding: 10px; border-radius: 4px; cursor: pointer;">Subscribe</button>
    </div>
  {% elsif active_template contains 'Animation' %}
    <div style="pointer-events: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 99999; display: flex; justify-content: center; align-items: flex-start;">
      <h2 style="color: {{ block.settings.text_color }}; font-size: 2rem; margin-top: 50px; opacity: 0.8; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">
        ✨ {{ active_template }} Effect ✨
      </h2>
    </div>
  {% else %}
    <div style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }}; text-align: center; padding: 15px; margin-bottom: 20px;">
      <h2 style="margin: 0; font-size: 1.5rem;">{{ block.settings.title | default: active_template }}</h2>
      <p style="margin: 5px 0 0 0;">{{ block.settings.subtitle }}</p>
    </div>
  {% endif %}

{% endif %}

{% schema %}
{
  "name": "Festive Decor",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#064E3B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Merry Christmas!"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Up to 70% Off - Limited Time Only"
    }
  ]
}
{% endschema %}
